# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Secrets
.env
backend/.env
backend/node_modules/
/node_modules/
/coverage/
# Firebase admin SDK service-account JSONs — Railway env var only,
# NEVER committed. Any leak gives full admin access to the project.
*-firebase-adminsdk-*.json
**/firebase-adminsdk-*.json

# Android release signing — the keystore + its password file must
# never be committed. Losing them means losing the ability to update
# the app on Play Store, leaking them means anyone can ship malware
# under your name.
android/key.properties
android/*.jks
**/key.properties
**/*.jks

# Local emulator runner — may carry the publishable Supabase key
# pre-filled. Publishable keys are technically safe to share, but
# keeping this file local avoids re-committing it every time someone
# tweaks the run config.
run-emulator.ps1

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
