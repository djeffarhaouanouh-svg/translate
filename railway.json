{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "Dockerfile",
      ".dockerignore",
      "backend/**",
      "lib/**",
      "web/**",
      "pubspec.yaml",
      "pubspec.lock",
      "railway.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health"
  }
}
