LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
PORT=8787

# OpenAI Realtime Translation
OPENAI_API_KEY=
# Optional: set to 1 to also transcribe source language (more latency / cost).
# OPENAI_TRANSLATION_TRANSCRIBE=0
# Optional: set to 0 to disable OpenAI's input noise reduction.
# OPENAI_TRANSLATION_NOISE_REDUCTION=1
# Server VAD threshold 0..1. Lower = more sensitive (whispers / quiet speech).
# Unset (default) → OpenAI's own defaults (~0.5). Try 0.2 if whispers do not trigger.
# OPENAI_TRANSLATION_VAD_THRESHOLD=0.2
# OPENAI_TRANSLATION_VAD_PREFIX_MS=300
# OPENAI_TRANSLATION_VAD_SILENCE_MS=400
