LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
PORT=8787

# OpenAI Realtime Translation
OPENAI_API_KEY=
# Optional: set to 1 to also transcribe source language (more latency / cost).
# OPENAI_TRANSLATION_TRANSCRIBE=0
# Optional: set to 0 to disable OpenAI's input noise reduction.
# OPENAI_TRANSLATION_NOISE_REDUCTION=1
# Server VAD threshold 0..1. Lower = more sensitive (whispers / quiet speech).
# Unset (default) → OpenAI's own defaults (~0.5). Try 0.2 if whispers do not trigger.
# OPENAI_TRANSLATION_VAD_THRESHOLD=0.2
# OPENAI_TRANSLATION_VAD_PREFIX_MS=300
# OPENAI_TRANSLATION_VAD_SILENCE_MS=400
# Pass the remote speaker's language to OpenAI as `audio.input.language`.
# Avoids the multi-minute warm-up where OpenAI auto-detects the source.
# Flip on to enable; flip off if OpenAI rejects the payload.
# OPENAI_TRANSLATION_PASS_INPUT_LANGUAGE=1

# ──────────────────────────────────────────────────────────────────────
# Push notification dispatcher (backend/notify.js).
# Every block below is OPTIONAL — the corresponding transport just
# becomes a no-op until configured. Set Supabase + at least one of
# (Web Push / Firebase) to start receiving notifications.

# Supabase service-role key — required for the dispatcher to read every
# user's notification_targets row regardless of RLS. NEVER ship this to
# the client / Flutter build args.
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# Web Push (RFC 8030). Generate once with:
#   npx web-push generate-vapid-keys
# Then keep the same pair in your prod env forever — changing it
# invalidates every existing browser subscription.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# Firebase Cloud Messaging — used to push to iOS + Android tokens.
# Paste the whole service-account JSON in FIREBASE_SERVICE_ACCOUNT_JSON
# (single-line, escaped) OR point FIREBASE_SERVICE_ACCOUNT_FILE at a
# JSON file on disk. Only one of the two is needed.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_FILE=/etc/secrets/firebase-sa.json

# ──────────────────────────────────────────────────────────────────────
# Stripe subscriptions (backend/stripe.js).
# Required for /api/stripe/checkout, /api/stripe/portal, and the
# /api/stripe/webhook handler. With these unset, the routes return 500
# and the website's "Souscrire" CTA stays inert.
#
# STRIPE_SECRET_KEY=sk_live_…   (NEVER ship to the Flutter build)
# STRIPE_WEBHOOK_SECRET=whsec_… (Developers → Webhooks → your endpoint)
# STRIPE_PRICE_PRO=price_…      (price object for Pro €29 / mo)
# STRIPE_PRICE_ULTRA=price_…    (price object for Ultra €59 / mo)
# Optional — override the redirect URLs (defaults point at swayco.fr).
# STRIPE_SUCCESS_URL=https://swayco.fr/?subscribed=1
# STRIPE_CANCEL_URL=https://swayco.fr/
# STRIPE_PORTAL_RETURN_URL=https://swayco.fr/

# ──────────────────────────────────────────────────────────────────────
# Analytics ingest (backend/analytics.js) — feeds the off-site admin
# dashboard. POST /api/events accepts batched app events and the
# translation routes emit server-side events. NO dedicated env vars:
# it reuses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY above. Unset →
# /api/events returns { error: 'supabase-not-configured' } and the
# analytics_events table simply stays empty.
#
# `country` is read best-effort from a CDN geo header when the backend
# sits behind one (cf-ipcountry / x-vercel-ip-country / …); nothing to
# configure — it just works when present, else the client locale-region
# hint is used.
