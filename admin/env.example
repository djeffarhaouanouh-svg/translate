# Swayco Admin — environment.
# Copy this file to `.env.local` (which is git-ignored) and fill it in.

# ── Supabase ──────────────────────────────────────────────────────────
# Same Supabase project as the Swayco app + backend.
#  * URL + anon key are public (used only for the admin sign-in).
#  * The service-role key BYPASSES RLS — it is what reads the locked
#    `analytics_events` table. Server-side only; never expose it.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cost rates (Monétisation) ─────────────────────────────────────────
# Cost = measured usage × these rates. They are 0 by default so nothing
# is invented — fill them from the CURRENT official pricing pages.
#   OpenAI Realtime translation — USD per minute of audio
COST_REALTIME_USD_PER_MIN=0
#   LiveKit Cloud — USD per participant-minute
COST_LIVEKIT_USD_PER_MIN=0
#   OpenAI gpt-4.1-mini text — USD per 1000 tokens (prompt+completion)
COST_TEXT_USD_PER_1K_TOKENS=0
#   FX rate used to express USD costs in the EUR margin
USD_TO_EUR=0.92

# ── Subscription prices (EUR / month) ─────────────────────────────────
# Used to turn the Pro / Ultra subscriber counts into MRR.
PRICE_PRO_EUR=29
PRICE_ULTRA_EUR=59
